# ==========================================
# Dunst — Windows 11 Toast Notifications
# ==========================================

[global]
    monitor                = 0
    follow                 = keyboard

    # Position — top-right like Win11
    origin                 = top-right
    offset                 = 12x52
    scale                  = 0
    notification_limit     = 5

    progress_bar           = true
    progress_bar_height    = 4
    progress_bar_frame_width = 0
    progress_bar_min_width = 200
    progress_bar_max_width = 360
    progress_bar_corner_radius = 2

    indicate_hidden        = yes
    transparency           = 10
    separator_height       = 1
    padding                = 12
    horizontal_padding     = 14
    text_icon_padding      = 10
    frame_width            = 1
    frame_color            = "#333333"
    gap_size               = 6
    separator_color        = frame
    sort                   = yes
    idle_threshold         = 120

    # Win11-style rounded toast
    corner_radius          = 8

    font                   = Noto Sans 11
    line_height            = 0
    markup                 = full
    format                 = "<b>%s</b>\n%b"
    alignment              = left
    vertical_alignment     = center
    show_age_threshold     = 60
    ellipsize              = middle
    ignore_newline         = no
    stack_duplicates       = true
    hide_duplicate_count   = false
    show_indicators        = yes

    min_icon_size          = 32
    max_icon_size          = 48
    icon_theme             = Fluent-dark, Adwaita
    enable_recursive_icon_lookup = true

    sticky_history         = yes
    history_length         = 20

    dmenu                  = /usr/bin/rofi -p dunst -dmenu
    browser                = /usr/bin/xdg-open

    always_run_script      = true
    title                  = Dunst
    class                  = Dunst
    ignore_dbusclose       = false

    mouse_left_click       = close_current
    mouse_middle_click     = do_action, close_current
    mouse_right_click      = close_all

[experimental]
    per_monitor_dpi        = false

[urgency_low]
    background             = "#1e1e1e"
    foreground             = "#ffffff"
    frame_color            = "#333333"
    timeout                = 4

[urgency_normal]
    background             = "#1e1e1e"
    foreground             = "#ffffff"
    frame_color            = "#0067C0"
    timeout                = 6

[urgency_critical]
    background             = "#1e1e1e"
    foreground             = "#ffffff"
    frame_color            = "#e74c3c"
    timeout                = 0
    icon                   = dialog-warning
